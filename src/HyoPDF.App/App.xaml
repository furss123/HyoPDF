<Application x:Class="HyoPDF.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters;assembly=HyoPDF.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Blue"
                                             SecondaryColor="Blue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HyoPDF.UI;component/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HyoPDF.UI;component/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
