<Window x:Class="HyoPDF.UI.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        Title="Settings"
        Width="440"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}">
    <Window.Resources>
        <conv:ThemePreferenceConverter x:Key="ThemeConverter" />
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
        <StackPanel>
            <TextBlock Text="Appearance" Style="{StaticResource TextTitle}" Margin="0,0,0,12" />

            <TextBlock Text="Theme" Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
            <ComboBox Style="{StaticResource FieldCombo}"
                      ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedTheme}"
                      Margin="0,0,0,12">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource ThemeConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Language" Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
            <ComboBox Style="{StaticResource FieldCombo}"
                      ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage}"
                      Margin="0,0,0,24" />

            <TextBlock Text="Viewer" Style="{StaticResource TextTitle}" Margin="0,0,0,12" />

            <TextBlock Text="Default zoom (%)" Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource FieldTextBox}"
                     Width="80"
                     HorizontalAlignment="Left"
                     Text="{Binding DefaultZoom, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12" />

            <CheckBox Content="Show sidebar by default"
                      IsChecked="{Binding SidebarVisible}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,0,24" />

            <Button Content="Close"
                    HorizontalAlignment="Right"
                    Style="{StaticResource ToolbarButton}"
                    IsDefault="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </ScrollViewer>
</Window>
