<Window x:Class="HyoPDF.UI.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        Title="설정"
        MinWidth="520"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <conv:ThemePreferenceConverter x:Key="ThemeConverter" />

        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SettingsFieldComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Padding" Value="12,8" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1E1E1E" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E1E1E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsFieldCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="BorderBrush" Value="#2A2A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsFieldComboItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="12,8"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#E8E8E8" />
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#909090"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1A1A1A"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Padding="2">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#111111"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
            <StackPanel>
                <TextBlock Text="설정"
                           Style="{StaticResource DialogTitle}" />

                <TextBlock Text="화면 설정"
                           Style="{StaticResource SettingsSectionHeader}" />

                <TextBlock Text="테마"
                           Style="{StaticResource DialogSectionLabel}" />
                <ComboBox Style="{StaticResource SettingsFieldCombo}"
                          ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding SelectedTheme}"
                          Margin="0,0,0,16">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ThemeConverter}}"
                                       Foreground="#E8E8E8" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="언어"
                           Style="{StaticResource DialogSectionLabel}" />
                <ComboBox Style="{StaticResource SettingsFieldCombo}"
                          ItemsSource="{Binding LanguageOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedItem="{Binding SelectedLanguageOption}"
                          Margin="0,0,0,20" />

                <TextBlock Text="뷰어 설정"
                           Style="{StaticResource SettingsSectionHeader}" />

                <TextBlock Text="기본 확대/축소 (%)"
                           Style="{StaticResource DialogSectionLabel}" />
                <TextBox Style="{StaticResource DialogFieldTextBox}"
                         Width="80"
                         HorizontalAlignment="Left"
                         Text="{Binding DefaultZoom, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <CheckBox Content="사이드바 기본 표시"
                          IsChecked="{Binding SidebarVisible}"
                          Foreground="#E8E8E8"
                          FontFamily="{StaticResource FontFamilyPrimary}"
                          FontSize="13"
                          Margin="0,0,0,20" />

                <Button Content="닫기"
                        HorizontalAlignment="Right"
                        Style="{StaticResource DialogSecondaryButton}"
                        IsDefault="True"
                        Click="OnCloseClick" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
