<UserControl x:Class="HyoPDF.UI.Views.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
             Height="44"
             Background="{DynamicResource BgSurfaceBrush}"
             BorderBrush="{DynamicResource BorderBrush}"
             BorderThickness="0,0,0,1">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
        <Button Style="{StaticResource ToolbarButton}"
                Content="{Binding OpenLabel}"
                Command="{Binding OpenFileCommand}" />

        <Button x:Name="RecentButton"
                Style="{StaticResource ToolbarButton}"
                Content="{Binding RecentFilesLabel}"
                Margin="4,0,0,0"
                Command="{Binding ToggleRecentFlyoutCommand}" />

        <Popup Placement="Bottom"
               PlacementTarget="{Binding ElementName=RecentButton}"
               IsOpen="{Binding IsRecentFlyoutOpen}"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource BgSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}"
                    Padding="8"
                    MinWidth="280"
                    MaxHeight="320">
                <StackPanel>
                    <TextBlock Text="{Binding NoRecentDocumentsLabel}"
                               Style="{StaticResource TextSecondary}"
                               Margin="8"
                               Visibility="{Binding HasRecentFiles, Converter={StaticResource InverseBoolToVis}}" />

                    <ListBox ItemsSource="{Binding RecentFiles}"
                             Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVis}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource ToolbarButton}"
                                            HorizontalContentAlignment="Left"
                                            Content="{Binding FileName}"
                                            ToolTip="{Binding Path}"
                                            Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding Path}" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ToolbarButton}"
                                            Content="×"
                                            Command="{Binding DataContext.RemoveRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Style="{StaticResource ToolbarButton}"
                            Content="{Binding ClearRecentLabel}"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVis}}"
                            Command="{Binding ClearRecentCommand}" />
                </StackPanel>
            </Border>
        </Popup>

        <Separator Width="1" Height="20" Margin="4,0" Background="{DynamicResource BorderBrush}" />
        <Button Style="{StaticResource ToolbarButton}" Content="−" Command="{Binding Viewer.ZoomOutCommand}" />
        <TextBlock Text="{Binding Viewer.ZoomLevel, StringFormat={}{0}%}"
                   Style="{StaticResource TextSecondary}"
                   VerticalAlignment="Center"
                   Margin="8,0"
                   MinWidth="40"
                   TextAlignment="Center" />
        <Button Style="{StaticResource ToolbarButton}" Content="+" Command="{Binding Viewer.ZoomInCommand}" />
        <Separator Width="1" Height="20" Margin="4,0" Background="{DynamicResource BorderBrush}" />
        <Button Style="{StaticResource ToolbarButton}" Content="↻" Command="{Binding Viewer.RotateCommand}" />
        <Separator Width="1" Height="20" Margin="4,0" Background="{DynamicResource BorderBrush}" />
        <TextBox x:Name="SearchBox"
                 Style="{StaticResource SearchTextBox}"
                 Width="200"
                 Text="{Binding Viewer.SearchQuery, UpdateSourceTrigger=PropertyChanged}">
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding Viewer.SearchCommand}" />
            </TextBox.InputBindings>
        </TextBox>
        <Button Style="{StaticResource ToolbarButton}"
                Content="{Binding SearchLabel}"
                Command="{Binding Viewer.SearchCommand}" />
        <Separator Width="1" Height="20" Margin="4,0" Background="{DynamicResource BorderBrush}" />
        <Button Style="{StaticResource ToolbarButton}" Content="◀" Command="{Binding Viewer.PrevPageCommand}" />
        <TextBlock VerticalAlignment="Center" Margin="8,0" Style="{StaticResource TextSecondary}">
            <Run Text="{Binding Viewer.CurrentPageNumber, Mode=OneWay}" />
            <Run Text="/" />
            <Run Text="{Binding Viewer.PageCount, Mode=OneWay}" />
        </TextBlock>
        <Button Style="{StaticResource ToolbarButton}" Content="▶" Command="{Binding Viewer.NextPageCommand}" />
        <Separator Width="1" Height="20" Margin="4,0" Background="{DynamicResource BorderBrush}" />
        <Button Style="{StaticResource ToolbarButton}"
                Content="☰"
                Command="{Binding ToggleSidebarCommand}" />
        <Button Style="{StaticResource ToolbarButton}"
                Content="{Binding PageManagerLabel}"
                Command="{Binding Page.TogglePanelCommand}" />
        <Button Style="{StaticResource ToolbarButton}"
                Content="{Binding CompressLabel}"
                Command="{Binding ShowCompressCommand}" />
        <Button Style="{StaticResource ToolbarButton}"
                Content="{Binding SettingsLabel}"
                Command="{Binding ShowSettingsCommand}" />
        <Button Style="{StaticResource ToolbarButton}"
                Content="{Binding AboutLabel}"
                Command="{Binding ShowAboutCommand}" />
    </StackPanel>
</UserControl>
