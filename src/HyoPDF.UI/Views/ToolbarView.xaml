<UserControl x:Class="HyoPDF.UI.Views.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BgSurfaceBrush}"
             BorderBrush="{DynamicResource BorderBrush}"
             BorderThickness="0,0,0,1"
             MinHeight="60">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <ScrollViewer x:Name="ToolbarScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  PanningMode="HorizontalOnly"
                  PreviewMouseWheel="ToolbarScrollViewer_PreviewMouseWheel">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,4,0" MinWidth="900">

            <!-- 열기 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding OpenFileCommand}"
                    ToolTip="{Binding OpenFileTooltipLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconOpenFolder}" />
                    <TextBlock Text="{Binding OpenLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 최근 ▾ -->
            <Button x:Name="RecentButton"
                    Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding ToggleRecentFlyoutCommand}"
                    ToolTip="{Binding RecentFilesLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconClosedFolder}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="{Binding RecentFilesShortLabel}"
                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                   FontSize="12"
                                   Foreground="#A0A0A0"
                                   TextWrapping="NoWrap" />
                        <TextBlock Text="▾"
                                   FontSize="10"
                                   Foreground="#A0A0A0"
                                   Margin="2,1,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Button>

            <Popup Placement="Bottom"
                   PlacementTarget="{Binding ElementName=RecentButton}"
                   IsOpen="{Binding IsRecentFlyoutOpen}"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="{DynamicResource BgSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}"
                        Padding="8"
                        MinWidth="280"
                        MaxHeight="320">
                    <StackPanel>
                        <TextBlock Text="{Binding NoRecentDocumentsLabel}"
                                   Style="{StaticResource TextSecondary}"
                                   Margin="8"
                                   Visibility="{Binding HasRecentFiles, Converter={StaticResource InverseBoolToVis}}" />
                        <ListBox ItemsSource="{Binding RecentFiles}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVis}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource ToolbarButton}"
                                                HorizontalContentAlignment="Left"
                                                Content="{Binding FileName}"
                                                ToolTip="{Binding Path}"
                                                Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding Path}" />
                                        <Button Grid.Column="1"
                                                Style="{StaticResource ToolbarButton}"
                                                Content="×"
                                                Command="{Binding DataContext.RemoveRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Style="{StaticResource ToolbarButton}"
                                Content="{Binding ClearRecentLabel}"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0"
                                Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVis}}"
                                Command="{Binding ClearRecentCommand}" />
                    </StackPanel>
                </Border>
            </Popup>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <!-- 확대 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Viewer.ZoomInCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding ZoomInLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconZoomIn}" />
                    <TextBlock Text="{Binding ZoomInLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 축소 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Viewer.ZoomOutCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding ZoomOutLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconZoomOut}" />
                    <TextBlock Text="{Binding ZoomOutLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 줌 레벨 -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,2,0">
                <TextBox x:Name="ZoomBox"
                         Style="{StaticResource ToolbarZoomLevelBox}"
                         IsEnabled="{Binding HasOpenDocument}"
                         ToolTip="{Binding ZoomInLabel}"
                         Text="{Binding Viewer.ZoomLevel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                <TextBlock Text="%"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="12"
                           Foreground="#A0A0A0" />
            </StackPanel>

            <!-- 맞춤 -->
            <Button Command="{Binding Viewer.ToggleFitToWidthCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding FitToWidthLabel}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Viewer.IsFitToWidth}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <materialDesign:PackIcon Kind="ArrowExpandHorizontal" Width="24" Height="24"
                                             HorizontalAlignment="Center">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Foreground" Value="{DynamicResource ToolbarIconBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Viewer.IsFitToWidth}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock Text="{Binding FitToWidthShortLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToolbarIconLabel}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Viewer.IsFitToWidth}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <!-- 회전 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Viewer.RotateCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding RotateLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconRotate}" />
                    <TextBlock Text="{Binding RotateLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 전체화면 -->
            <Button Command="{Binding Viewer.ToggleFullscreenCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding FullscreenTooltipLabel}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Viewer.IsFullscreen}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <materialDesign:PackIcon Kind="Fullscreen" Width="24" Height="24"
                                             HorizontalAlignment="Center">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Foreground" Value="{DynamicResource ToolbarIconBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Viewer.IsFullscreen}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock Text="{Binding FullscreenLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToolbarIconLabel}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Viewer.IsFullscreen}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <!-- 이전 (icon only) -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Viewer.PrevPageCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding PrevPageLabel}">
                <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"
                                         Foreground="{DynamicResource ToolbarIconBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
            </Button>

            <!-- 페이지 번호 -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="2,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Opacity" Value="0.35" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasOpenDocument}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBox x:Name="PageInputBox"
                         Style="{StaticResource PageInputTextBox}"
                         IsEnabled="{Binding HasOpenDocument}"
                         PreviewTextInput="PageInputBox_PreviewTextInput"
                         PreviewKeyDown="PageInputBox_PreviewKeyDown"
                         KeyDown="PageInputBox_KeyDown"
                         LostFocus="PageInputBox_LostFocus" />
                <TextBlock VerticalAlignment="Center"
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="13"
                           Foreground="#E0E0E0"
                           TextWrapping="NoWrap"
                           Margin="2,0,0,0">
                    <Run Text="/" />
                    <Run Text="{Binding Viewer.PageCount, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>

            <!-- 다음 (icon only) -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Viewer.NextPageCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding NextPageLabel}">
                <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"
                                         Foreground="{DynamicResource ToolbarIconBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <!-- 검색 -->
            <Grid VerticalAlignment="Center" Margin="2,0,4,0">
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource ToolbarSearchTextBox}"
                         IsEnabled="{Binding HasOpenDocument}"
                         ToolTip="{Binding SearchLabel}"
                         Text="{Binding Viewer.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="SearchBox_PreviewKeyDown" />
                <materialDesign:PackIcon Kind="Magnify"
                                         Width="16" Height="16"
                                         Margin="8,0,0,0"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Left"
                                         IsHitTestVisible="False"
                                         Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding SearchPlaceholderLabel}"
                           IsHitTestVisible="False"
                           Margin="30,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <!-- 병합 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Page.MergeCommand}"
                    ToolTip="{Binding MergePdfTooltipLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconMerge}" />
                    <TextBlock Text="{Binding MergeLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 분할 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding Page.SplitCommand}"
                    IsEnabled="{Binding HasOpenDocument}"
                    ToolTip="{Binding SplitPdfTooltipLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconSplit}" />
                    <TextBlock Text="{Binding SplitLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 압축 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding ShowCompressCommand}"
                    ToolTip="{Binding CompressLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconCompress}" />
                    <TextBlock Text="{Binding CompressLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <!-- 인쇄 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding ShowPrintCommand}"
                    ToolTip="{Binding PrintLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconPrint}" />
                    <TextBlock Text="{Binding PrintLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <!-- 설정 -->
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding ShowSettingsCommand}"
                    ToolTip="{Binding SettingsLabel}">
                <StackPanel Style="{StaticResource ToolbarButtonStack}">
                    <Image Style="{StaticResource ToolbarVoxelIcon}"
                           Source="{StaticResource ToolbarIconSettings}" />
                    <TextBlock Text="{Binding SettingsLabel}" Style="{StaticResource ToolbarIconLabel}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
