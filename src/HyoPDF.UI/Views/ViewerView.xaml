<UserControl x:Class="HyoPDF.UI.Views.ViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:HyoPDF.UI.Behaviors"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
             xmlns:vm="clr-namespace:HyoPDF.UI.ViewModels"
             behaviors:DragDropBehavior.IsEnabled="True"
             Background="{DynamicResource BgBaseBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolVis" />
        <DataTemplate DataType="{x:Type vm:PdfPageItemViewModel}" x:Key="PageTemplate">
            <Grid Margin="0,12" HorizontalAlignment="Center" Tag="{Binding PageIndex}">
                <Border Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="{StaticResource RadiusMd}"
                        Padding="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid Width="{Binding DisplayWidth}"
                          Height="{Binding DisplayHeight}">
                        <Image Source="{Binding PageImage}"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <ItemsControl ItemsSource="{Binding HighlightRects}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Rectangle Fill="#400078D4"
                                               Stroke="{DynamicResource AccentBrush}"
                                               StrokeThickness="1"
                                               RadiusX="2"
                                               RadiusY="2"
                                               Width="{Binding Width}"
                                               Height="{Binding Height}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="PageScrollViewer"
                      DataContext="{Binding Viewer}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly"
                      ScrollChanged="OnScrollChanged"
                      Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}">
            <ItemsControl x:Name="PagesItemsControl"
                          ItemsSource="{Binding Pages}"
                          ItemTemplate="{StaticResource PageTemplate}"
                          HorizontalAlignment="Center"
                          Margin="24,16" />
        </ScrollViewer>

        <Border Style="{StaticResource PanelBorder}"
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="480"
                MinHeight="360"
                Visibility="{Binding Viewer.HasDocument, Converter={StaticResource InverseBoolVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📄"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />
                <TextBlock Text="{Binding DropPdfLabel}"
                           Style="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
