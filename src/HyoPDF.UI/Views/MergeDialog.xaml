<Window x:Class="HyoPDF.UI.Views.MergeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge PDFs"
        Width="480"
        Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select PDF files to merge (drag to reorder)"
                   Style="{StaticResource TextSecondary}"
                   Margin="0,0,0,8" />

        <ListBox x:Name="FileList"
                 Grid.Row="1"
                 AllowDrop="True"
                 Background="{DynamicResource BgSurfaceBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 PreviewMouseLeftButtonDown="OnListMouseDown"
                 PreviewMouseMove="OnListMouseMove"
                 Drop="OnListDrop" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Add files..."
                    Style="{StaticResource ToolbarButton}"
                    Click="OnAddFiles" />
            <Button Content="Remove"
                    Style="{StaticResource ToolbarButton}"
                    Margin="8,0,0,0"
                    Click="OnRemove" />
            <Button Content="Include current document"
                    Style="{StaticResource ToolbarButton}"
                    Margin="8,0,0,0"
                    Click="OnIncludeCurrent" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource ToolbarButton}"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button Content="Merge into current"
                    Style="{StaticResource ToolbarButton}"
                    Margin="0,0,8,0"
                    Click="OnMergeIntoCurrent" />
            <Button Content="Merge to file..."
                    Style="{StaticResource ToolbarButton}"
                    IsDefault="True"
                    Click="OnMergeToFile" />
        </StackPanel>
    </Grid>
</Window>
