<Window x:Class="HyoPDF.UI.Views.MergeDialog"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"

        Title="PDF 병합"

        Width="640"

        MinWidth="520"

        Height="520"

        WindowStartupLocation="CenterOwner"

        ResizeMode="NoResize"

        WindowStyle="None"

        AllowsTransparency="True"

        Background="Transparent">

    <Window.Resources>

        <Style x:Key="MergeRowIconButton" TargetType="Button">

            <Setter Property="Width" Value="20" />

            <Setter Property="Height" Value="20" />

            <Setter Property="Background" Value="Transparent" />

            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Foreground" Value="#505050" />

            <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />

            <Setter Property="FontSize" Value="12" />

            <Setter Property="Padding" Value="0" />

            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="Transparent">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Foreground" Value="#E8E8E8" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="MergeFileListItem" TargetType="ListBoxItem">

            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Setter Property="Padding" Value="8,0" />

            <Setter Property="Margin" Value="0,2" />

            <Setter Property="Height" Value="44" />

            <Setter Property="Background" Value="Transparent" />

            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="ListBoxItem">

                        <Border x:Name="rowBorder"

                                Background="Transparent"

                                CornerRadius="8"

                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="rowBorder" Property="Background" Value="#1E1E1E" />

                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">

                                <Setter TargetName="rowBorder" Property="Background" Value="#1E1E1E" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>



    <Border x:Name="DialogRoot"

            Background="#111111"

            BorderBrush="{DynamicResource BorderBrush}"

            BorderThickness="1"

            CornerRadius="12"

            Margin="8"

            AllowDrop="True"

            PreviewDragOver="OnWindowDragOver"

            Drop="OnWindowDrop">

        <Grid Margin="28">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />

                <RowDefinition Height="*" />

                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />

            </Grid.RowDefinitions>



            <TextBlock Grid.Row="0"

                       Text="PDF 병합"

                       Style="{StaticResource DialogTitle}" />



            <Grid x:Name="DropZone"

                  Grid.Row="1"

                  MinHeight="130"

                  Margin="0,0,0,20"

                  AllowDrop="True"

                  PreviewDragOver="OnWindowDragOver"

                  Drop="OnWindowDrop">

                <Rectangle RadiusX="12"

                           RadiusY="12"

                           Stroke="#333333"

                           StrokeThickness="1.5"

                           StrokeDashArray="6 4"

                           Fill="#161616" />

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <materialDesign:PackIcon Kind="FilePdfBox"

                                             Width="32"

                                             Height="32"

                                             Foreground="#404040"

                                             HorizontalAlignment="Center"

                                             Margin="0,0,0,12" />

                    <TextBlock Text="PDF 파일을 드래그하세요"

                               FontFamily="{StaticResource FontFamilyPrimary}"

                               FontSize="14"

                               Foreground="#909090"

                               HorizontalAlignment="Center"

                               Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <TextBlock Text="또는"

                                   FontFamily="{StaticResource FontFamilyPrimary}"

                                   FontSize="14"

                                   Foreground="#909090"

                                   VerticalAlignment="Center"

                                   Margin="0,0,6,0" />

                        <Button Style="{StaticResource DialogLinkButton}"

                                Content="파일 추가"

                                Command="{Binding AddFilesCommand}" />

                    </StackPanel>

                </StackPanel>

            </Grid>



            <TextBlock Grid.Row="2"

                       Text="병합할 파일"

                       Style="{StaticResource DialogSectionLabel}" />



            <Grid Grid.Row="3" Margin="0,0,0,20">

                <ListBox x:Name="FileList"

                         ItemsSource="{Binding Files}"

                         AllowDrop="True"

                         Background="Transparent"

                         BorderThickness="0"

                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"

                         ItemContainerStyle="{StaticResource MergeFileListItem}"

                         PreviewMouseLeftButtonDown="OnListMouseDown"

                         PreviewMouseMove="OnListMouseMove"

                         DragOver="OnListDragOver"

                         DragLeave="OnListDragLeave"

                         Drop="OnListDrop">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Grid>

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="Auto" />

                                    <ColumnDefinition Width="*" />

                                    <ColumnDefinition Width="Auto" />

                                </Grid.ColumnDefinitions>



                                <Border Grid.Column="0"

                                        Background="#E5484D"

                                        CornerRadius="2"

                                        Padding="4,2"

                                        Margin="0,0,10,0"

                                        VerticalAlignment="Center">

                                    <TextBlock Text="PDF"

                                               FontFamily="{StaticResource FontFamilyPrimary}"

                                               FontSize="8"

                                               FontWeight="SemiBold"

                                               Foreground="White" />

                                </Border>



                                <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                    <TextBlock Text="{Binding FileName}"

                                               ToolTip="{Binding FilePath}"

                                               FontFamily="{StaticResource FontFamilyPrimary}"

                                               FontSize="14"

                                               Foreground="#E8E8E8"

                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding FileSize}"

                                               FontFamily="{StaticResource FontFamilyPrimary}"

                                               FontSize="12"

                                               Foreground="#606060"

                                               Margin="0,2,0,0" />

                                </StackPanel>



                                <StackPanel Grid.Column="2"

                                            Orientation="Horizontal"

                                            VerticalAlignment="Center"

                                            Margin="8,0,0,0">

                                    <Button Style="{StaticResource MergeRowIconButton}"

                                            Content="↑"

                                            ToolTip="위로"

                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"

                                            CommandParameter="{Binding}" />

                                    <Button Style="{StaticResource MergeRowIconButton}"

                                            Content="↓"

                                            Margin="4,0,0,0"

                                            ToolTip="아래로"

                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"

                                            CommandParameter="{Binding}" />

                                    <Button Style="{StaticResource MergeRowIconButton}"

                                            Content="✕"

                                            Margin="8,0,0,0"

                                            ToolTip="제거"

                                            Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"

                                            CommandParameter="{Binding}" />

                                </StackPanel>

                            </Grid>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>



                <Border x:Name="DropIndicator"

                        Height="2"

                        Background="{DynamicResource AccentBrush}"

                        HorizontalAlignment="Stretch"

                        VerticalAlignment="Top"

                        Margin="8,0"

                        Visibility="Collapsed"

                        IsHitTestVisible="False" />

            </Grid>



            <TextBlock Grid.Row="4"

                       Text="저장 위치"

                       Style="{StaticResource DialogSectionLabel}" />



            <Grid Grid.Row="5" Margin="0,0,0,20">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*" />

                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"

                         Style="{StaticResource DialogFieldTextBox}"

                         IsReadOnly="True"

                         Text="{Binding OutputPath, Mode=OneWay}" />

                <Button Grid.Column="1"

                        Content="찾기"

                        Style="{StaticResource DialogBrowseButton}"

                        Margin="8,0,0,0"

                        Command="{Binding SelectOutputCommand}" />

            </Grid>



            <StackPanel Grid.Row="6"

                        Orientation="Horizontal"

                        HorizontalAlignment="Right">

                <Button Content="취소"

                        Style="{StaticResource DialogSecondaryButton}"

                        Margin="0,0,8,0"

                        IsCancel="True" />

                <Button Content="병합 시작"

                        Style="{StaticResource DialogPrimaryButton}"

                        IsDefault="True"

                        Command="{Binding MergeCommand}" />

            </StackPanel>

        </Grid>

    </Border>

</Window>

