<Window x:Class="HyoPDF.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HyoPDF 정보"
        Width="420"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusLg}"
            Padding="32"
            Margin="16">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="HyoPDF"
                       Style="{StaticResource TextTitle}"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14" />
            <TextBlock HorizontalAlignment="Center"
                       Style="{StaticResource TextSecondary}"
                       TextAlignment="Center"
                       Margin="0,0,0,8">
                <Run Text="{Binding FooterText}" />
                <Hyperlink NavigateUri="https://hyot.dev"
                           RequestNavigate="OnLinkNavigate">
                    hyot.dev
                </Hyperlink>
            </TextBlock>
            <Button x:Name="OkButton"
                    Margin="0,24,0,0"
                    Padding="24,8"
                    HorizontalAlignment="Center"
                    Style="{StaticResource ToolbarButton}"
                    Click="OnCloseClick" />
        </StackPanel>
    </Border>
</Window>
