<UserControl x:Class="HyoPDF.UI.Views.TitleBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="40"
             Background="{DynamicResource BgSurfaceBrush}"
             AllowDrop="True"
             PreviewDragOver="OnDragOver"
             Drop="OnDrop">
    <UserControl.Resources>
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,8,10,10" />
            <Setter Property="Margin" Value="2,4,2,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="tabBorder"
                                    Background="Transparent"
                                    CornerRadius="8,8,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                    <Button Content="×"
                                            Margin="8,0,0,0"
                                            Padding="4,0"
                                            FontSize="12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                            <Border x:Name="accentLine"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource AccentBrush}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="accentLine" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ListBox x:Name="TabList"
                 Grid.Column="0"
                 ItemsSource="{Binding DocumentTabs.Tabs}"
                 SelectedItem="{Binding DocumentTabs.ActiveTab, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemContainerStyle="{StaticResource TabItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 AllowDrop="True"
                 PreviewDragOver="OnDragOver"
                 Drop="OnDrop">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
            <Button Style="{StaticResource WindowButton}" Content="&#xE921;" Click="MinimizeClick" />
            <Button Style="{StaticResource WindowButton}" Content="&#xE922;" Click="MaximizeClick" />
            <Button Style="{StaticResource WindowButton}" Content="&#xE8BB;" Click="CloseClick" />
        </StackPanel>
    </Grid>
</UserControl>
