<UserControl x:Class="HyoPDF.UI.Views.TitleBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
             Height="32"
             Background="{DynamicResource TitleBarBgBrush}"
             AllowDrop="True"
             PreviewDragOver="OnDragOver"
             Drop="OnDrop">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MaxWidth" Value="200" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="tabRoot">
                            <Border x:Name="tabBorder"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FileName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button x:Name="closeBtn"
                                            Grid.Column="1"
                                            Content="×"
                                            Margin="8,0,0,0"
                                            Padding="4,0"
                                            FontSize="12"
                                            Visibility="Collapsed"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Cursor="Hand"
                                            WindowChrome.IsHitTestVisibleInChrome="True"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="closeBorder"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="closeBorder" Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                            <Border x:Name="accentLine"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource AccentBrush}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="accentLine" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                                <Setter TargetName="closeBtn" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
                                <Setter TargetName="closeBtn" Property="Visibility" Value="Visible" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Background" Value="#E81123" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="12,0,16,0">
            <Image Source="{StaticResource AppIconImage}"
                   Width="16"
                   Height="16"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Margin="0,0,8,0" />
            <TextBlock Text="HyoPDF"
                       FontFamily="{StaticResource FontFamilyPrimary}"
                       FontSize="13"
                       Foreground="{DynamicResource TitleBarTextBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <ListBox x:Name="TabList"
                 Grid.Column="1"
                 ItemsSource="{Binding DocumentTabs.Tabs}"
                 SelectedItem="{Binding DocumentTabs.ActiveTab, Mode=TwoWay}"
                 Visibility="{Binding DocumentTabs.ShowTabStrip, Converter={StaticResource BoolToVis}}"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalAlignment="Center"
                 ItemContainerStyle="{StaticResource TabItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 WindowChrome.IsHitTestVisibleInChrome="True"
                 AllowDrop="True"
                 PreviewDragOver="OnDragOver"
                 Drop="OnDrop">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
            <Button Style="{StaticResource WindowButton}" Content="&#xE921;" Click="MinimizeClick" />
            <Button Style="{StaticResource WindowButton}" Content="&#xE922;" Click="MaximizeClick" />
            <Button Style="{StaticResource CloseWindowButton}" Content="&#xE8BB;" Click="CloseClick" />
        </StackPanel>
    </Grid>
</UserControl>
