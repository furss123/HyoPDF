<UserControl x:Class="HyoPDF.UI.Views.PageManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
             xmlns:vm="clr-namespace:HyoPDF.UI.ViewModels"
             Width="320"
             Background="{DynamicResource BgSurfaceBrush}"
             BorderBrush="{DynamicResource BorderBrush}"
             BorderThickness="1,0,0,0">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:PdfPageItemViewModel}">
            <Border x:Name="ThumbBorder"
                    Width="88"
                    Margin="4"
                    Padding="4"
                    CornerRadius="{StaticResource RadiusSm}"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    Tag="{Binding PageIndex}"
                    MouseLeftButtonDown="OnThumbnailMouseDown"
                    PreviewMouseMove="OnThumbnailPreviewMouseMove"
                    PreviewMouseLeftButtonUp="OnThumbnailMouseUp">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <MenuItem Header="{Binding DeleteLabel}" Command="{Binding Page.DeleteSelectedCommand}" />
                        <MenuItem Header="{Binding Rotate90Label}" Command="{Binding Page.RotateSelected90Command}" />
                        <MenuItem Header="{Binding Rotate180Label}" Command="{Binding Page.RotateSelected180Command}" />
                        <MenuItem Header="{Binding Rotate270Label}" Command="{Binding Page.RotateSelected270Command}" />
                        <Separator />
                        <MenuItem Header="{Binding ExtractPagesLabel}" Command="{Binding Page.ExtractSelectedCommand}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Image Source="{Binding Thumbnail}"
                           Width="80"
                           Height="110"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="{Binding PageNumber}"
                               Style="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid DataContext="{Binding Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding DataContext.PageManagerLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Style="{StaticResource TextTitle}"
                               DockPanel.Dock="Left" />
                    <Button Content="×"
                            DockPanel.Dock="Right"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding TogglePanelCommand}" />
                </DockPanel>
                <WrapPanel DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Button Style="{StaticResource ToolbarButton}" Content="{Binding MergeLabel}" Command="{Binding Page.MergeCommand}" Margin="0,0,4,4" />
                    <Button Style="{StaticResource ToolbarButton}" Content="{Binding SplitLabel}" Command="{Binding Page.SplitCommand}" Margin="0,0,4,4" />
                    <Button Style="{StaticResource ToolbarButton}" Content="{Binding ExtractLabel}" Command="{Binding Page.ExtractSelectedCommand}" Margin="0,0,4,4" />
                    <Button Style="{StaticResource ToolbarButton}" Content="{Binding DeleteLabel}" Command="{Binding Page.DeleteSelectedCommand}" Margin="0,0,4,4" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      AllowDrop="True"
                      DragOver="OnDragOver"
                      Drop="OnDrop">
            <ItemsControl x:Name="ThumbnailGrid"
                          ItemsSource="{Binding DataContext.Viewer.Pages, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
