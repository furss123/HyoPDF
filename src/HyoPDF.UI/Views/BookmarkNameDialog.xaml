<Window x:Class="HyoPDF.UI.Views.BookmarkNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="북마크 추가"
        Width="360"
        MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="OnKeyDown">
    <Border Background="#111111"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="북마크 추가"
                       Style="{StaticResource DialogTitle}" />

            <TextBox x:Name="TitleTextBox"
                     Grid.Row="1"
                     Margin="0,0,0,24"
                     Style="{StaticResource DialogFieldTextBox}"
                     Text="{Binding BookmarkTitle, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="취소"
                        Style="{StaticResource DialogSecondaryButton}"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnCancelClick" />
                <Button Content="추가"
                        Style="{StaticResource DialogPrimaryButton}"
                        IsDefault="True"
                        Click="OnAddClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
