<Window x:Class="HyoPDF.UI.Views.CompressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        Title="Compress PDF"
        Width="520"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}">
    <Window.Resources>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Input file" Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource FieldTextBox}" Text="{Binding InputPath, Mode=OneWay}" IsReadOnly="True" />
            <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource ToolbarButton}" Content="..." Command="{Binding BrowseInputCommand}" />
        </Grid>

        <TextBlock Grid.Row="2" Text="Compression level" Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <Slider Minimum="1" Maximum="5"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    Value="{Binding SelectedLevelSlider}" />
            <UniformGrid Columns="5" Margin="0,4,0,0">
                <TextBlock Text="{Binding Level1Label}" Style="{StaticResource TextSecondary}" FontSize="11" TextAlignment="Center" />
                <TextBlock Text="{Binding Level2Label}" Style="{StaticResource TextSecondary}" FontSize="11" TextAlignment="Center" />
                <TextBlock Text="{Binding Level3Label}" Style="{StaticResource TextSecondary}" FontSize="11" TextAlignment="Center" />
                <TextBlock Text="{Binding Level4Label}" Style="{StaticResource TextSecondary}" FontSize="11" TextAlignment="Center" />
                <TextBlock Text="{Binding Level5Label}" Style="{StaticResource TextSecondary}" FontSize="11" TextAlignment="Center" />
            </UniformGrid>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Original size" Style="{StaticResource TextSecondary}" FontSize="11" />
                <TextBlock Text="{Binding OriginalSizeText}" Style="{StaticResource TextPrimary}" />
            </StackPanel>
            <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center" Margin="12,0" Style="{StaticResource TextSecondary}" />
            <StackPanel Grid.Column="2">
                <TextBlock Text="Estimated size" Style="{StaticResource TextSecondary}" FontSize="11" />
                <TextBlock Text="{Binding EstimatedSizeText}" Style="{StaticResource TextPrimary}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="5" Text="Output file" Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource FieldTextBox}" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource ToolbarButton}" Content="..." Command="{Binding BrowseOutputCommand}" />
        </Grid>

        <StackPanel Grid.Row="7" Visibility="{Binding IsCompressing, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Compressing..." Style="{StaticResource TextSecondary}" Margin="0,0,0,4" />
            <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding Progress}" />
        </StackPanel>

        <TextBlock Grid.Row="7"
                   Text="{Binding ErrorMessage}"
                   Foreground="#E57373"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}" />

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource ToolbarButton}"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"
                    IsCancel="True" />
            <Button Content="Compress"
                    Style="{StaticResource ToolbarButton}"
                    Command="{Binding CompressCommand}"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
