<Window x:Class="HyoPDF.UI.Views.CompressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PDF 압축"
        Width="520"
        MinWidth="520"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        AllowDrop="True"
        PreviewDragOver="OnWindowDragOver"
        DragLeave="OnWindowDragLeave"
        Drop="OnWindowDrop">
    <Window.Resources>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <conv:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="#111111"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="PDF 압축"
                       Style="{StaticResource DialogTitle}" />

            <Border x:Name="DropZone"
                    Grid.Row="1"
                    MinHeight="130"
                    Margin="0,0,0,20"
                    AllowDrop="True"
                    PreviewDragOver="OnWindowDragOver"
                    DragLeave="OnDropZoneDragLeave"
                    Drop="OnWindowDrop"
                    Visibility="{Binding InputPath, Converter={StaticResource StringEmptyToVis}}">
                <Grid>
                    <Rectangle x:Name="DropZoneRect"
                               RadiusX="12"
                               RadiusY="12"
                               Stroke="#333333"
                               StrokeThickness="1.5"
                               StrokeDashArray="6 4"
                               Fill="#161616" />
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="FilePdfBox"
                                                 Width="32"
                                                 Height="32"
                                                 Foreground="#404040"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,12" />
                        <TextBlock Text="PDF 파일을 드래그하세요"
                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                   FontSize="14"
                                   Foreground="#909090"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="또는"
                                       FontFamily="{StaticResource FontFamilyPrimary}"
                                       FontSize="14"
                                       Foreground="#909090"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <Button Style="{StaticResource DialogLinkButton}"
                                    Content="파일 선택"
                                    Command="{Binding BrowseInputCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,20"
                    Padding="12,10"
                    Background="#1A1A1A"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding InputPath, Converter={StaticResource StringNotEmptyToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding InputPath}"
                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                   FontSize="14"
                                   Foreground="#E8E8E8"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding InputPath}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="변경"
                            Style="{StaticResource DialogLinkButton}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding BrowseInputCommand}" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="압축 품질"
                       Style="{StaticResource DialogSectionLabel}" />

            <StackPanel Grid.Row="3" Margin="0,0,0,20">
                <Slider Minimum="1"
                        Maximum="5"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        TickPlacement="BottomRight"
                        Value="{Binding SelectedLevelSlider, Mode=TwoWay}" />
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="최소 용량"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               TextAlignment="Center"
                               FontSize="11"
                               Foreground="#909090" />
                    <TextBlock Grid.Column="1"
                               Text="저품질"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               TextAlignment="Center"
                               FontSize="11"
                               Foreground="#909090" />
                    <TextBlock Grid.Column="2"
                               Text="균형"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               TextAlignment="Center"
                               FontSize="11"
                               Foreground="#909090" />
                    <TextBlock Grid.Column="3"
                               Text="고품질"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               TextAlignment="Center"
                               FontSize="11"
                               Foreground="#909090" />
                    <TextBlock Grid.Column="4"
                               Text="최고 화질"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               TextAlignment="Center"
                               FontSize="11"
                               Foreground="#909090" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        Margin="0,0,0,20">
                <TextBlock FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="13"
                           Foreground="#909090">
                    <Run Text="원본 크기: " />
                    <Run Text="{Binding OriginalSizeText, Mode=OneWay}"
                         Foreground="#E8E8E8" />
                </TextBlock>
                <TextBlock FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="13"
                           Foreground="#909090"
                           Margin="24,0,0,0">
                    <Run Text="예상 크기: " />
                    <Run Text="{Binding EstimatedSizeText, Mode=OneWay}"
                         Foreground="#E8E8E8" />
                </TextBlock>
            </StackPanel>

            <TextBlock Grid.Row="5"
                       Text="저장 위치"
                       Style="{StaticResource DialogSectionLabel}" />

            <Grid Grid.Row="6" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource DialogFieldTextBox}"
                         Padding="4,8,12,8"
                         Margin="0"
                         Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Content="찾기"
                        Style="{StaticResource DialogBrowseButton}"
                        Margin="8,0,0,0"
                        Command="{Binding BrowseOutputCommand}" />
            </Grid>

            <StackPanel Grid.Row="7"
                        Visibility="{Binding IsCompressing, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,12">
                <TextBlock Text="압축 중..."
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="12"
                           Foreground="#909090"
                           Margin="0,0,0,6" />
                <ProgressBar Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding Progress}" />
            </StackPanel>

            <TextBlock Grid.Row="7"
                       Text="{Binding ErrorMessage}"
                       Foreground="#E57373"
                       FontFamily="{StaticResource FontFamilyPrimary}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}" />

            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="취소"
                        Style="{StaticResource DialogSecondaryButton}"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        IsCancel="True" />
                <Button Content="압축 시작"
                        Style="{StaticResource DialogPrimaryButton}"
                        Command="{Binding CompressCommand}"
                        IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
