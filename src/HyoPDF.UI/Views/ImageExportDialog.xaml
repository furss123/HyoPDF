<Window x:Class="HyoPDF.UI.Views.ImageExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        Title="이미지 변환 설정"
        Width="720"
        MinWidth="720"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <Border Background="#111111"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       Style="{StaticResource DialogTitle}" />

            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="{Binding FormatLabel}"
                           Style="{StaticResource DialogSectionLabel}" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="PNG"
                                 GroupName="ImageFormat"
                                 IsChecked="{Binding IsPngFormat, Mode=TwoWay}"
                                 Foreground="#E8E8E8"
                                 FontFamily="{StaticResource FontFamilyPrimary}"
                                 FontSize="13"
                                 Margin="0,0,20,0" />
                    <RadioButton Content="JPG"
                                 GroupName="ImageFormat"
                                 IsChecked="{Binding IsJpgFormat, Mode=TwoWay}"
                                 Foreground="#E8E8E8"
                                 FontFamily="{StaticResource FontFamilyPrimary}"
                                 FontSize="13"
                                 Margin="0,0,20,0" />
                    <RadioButton Content="BMP"
                                 GroupName="ImageFormat"
                                 IsChecked="{Binding IsBmpFormat, Mode=TwoWay}"
                                 Foreground="#E8E8E8"
                                 FontFamily="{StaticResource FontFamilyPrimary}"
                                 FontSize="13" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="{Binding QualityLabel}"
                           Style="{StaticResource DialogSectionLabel}" />
                <Grid IsEnabled="{Binding IsQualityEnabled}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                            Minimum="1"
                            Maximum="100"
                            Value="{Binding Quality}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding QualityText}"
                               Foreground="#E8E8E8"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               MinWidth="40" />
                </Grid>
                <TextBlock Text="{Binding QualityHint}"
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="11"
                           Foreground="#707070"
                           Margin="0,4,0,0"
                           Visibility="{Binding IsQualityEnabled, Converter={StaticResource InverseBoolToVis}}" />
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="480" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding OutputFolderLabel}"
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           FontSize="12"
                           Foreground="#909090"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBox Grid.Column="1"
                         Height="36"
                         Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFieldTextBox}"
                         Padding="8,0,12,0"
                         Margin="0,0,8,0"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="2"
                        Content="→"
                        Height="36"
                        MinWidth="36"
                        Padding="0"
                        Style="{StaticResource DialogBrowseButton}"
                        Margin="0,0,8,0"
                        Command="{Binding OpenOutputFolderCommand}"
                        ToolTip="{Binding OpenFolderLabel}" />
                <Button Grid.Column="3"
                        Content="{Binding BrowseLabel}"
                        Height="36"
                        MinWidth="64"
                        Padding="12,0"
                        Style="{StaticResource DialogBrowseButton}"
                        Margin="0,0,16,0"
                        Command="{Binding SelectFolderCommand}" />
                <Button Grid.Column="5"
                        Content="{Binding CancelLabel}"
                        Height="36"
                        MinWidth="88"
                        Padding="10,0"
                        Style="{StaticResource DialogSecondaryButton}"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Grid.Column="6"
                        Content="{Binding ExportLabel}"
                        Height="36"
                        MinWidth="108"
                        Padding="24,0"
                        Style="{StaticResource DialogPrimaryButton}"
                        IsDefault="True"
                        Click="OnExportClick" />
            </Grid>
        </Grid>
    </Border>
</Window>
