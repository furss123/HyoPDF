<UserControl x:Class="HyoPDF.UI.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:HyoPDF.Core.Models;assembly=HyoPDF.Core"
             xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource SidebarBgBrush}"
             BorderBrush="{DynamicResource BorderBrush}"
             BorderThickness="0,0,1,0"
             ClipToBounds="False"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToAccentBrushConverter x:Key="BoolToAccentBrushConverter" />
        <conv:BoolToSelectedBgConverter x:Key="BoolToSelectedBgConverter" />
        <conv:CutOpacityConverter x:Key="CutOpacityConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />

        <Style x:Key="ScrollBarTrackRepeatButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.01" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0DFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarThumbnailScrollBar" TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Width="12">
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand"
                                                          Style="{StaticResource ScrollBarTrackRepeatButton}" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand"
                                                          Style="{StaticResource ScrollBarTrackRepeatButton}" />
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb x:Name="ThumbEl">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#484848"
                                                                CornerRadius="6"
                                                                Margin="3,2"
                                                                MinHeight="60" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBorder"
                                                                        Property="Background"
                                                                        Value="#686868" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HiddenScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HiddenRepeatButton" TargetType="RepeatButton">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Width" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarSectionHeader" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,12,12,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource SidebarSectionHeader}" />
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              Focusable="False" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarExpanderFill" TargetType="Expander" BasedOn="{StaticResource SidebarExpander}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="HeaderToggle"
                                          Grid.Row="0"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource SidebarSectionHeader}" />
                            <ContentPresenter x:Name="ExpandSite"
                                              Grid.Row="1"
                                              Visibility="Collapsed"
                                              Focusable="False"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BookmarkTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="False"
          VerticalAlignment="Stretch">
        <Grid Margin="0,8,0,0"
              VerticalAlignment="Stretch"
              Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Expander Grid.Row="0"
                      Style="{StaticResource SidebarExpander}">
                <Expander.Header>
                    <TextBlock Text="{Binding BookmarksLabel}"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Expander.Header>
                <ScrollViewer x:Name="BookmarkScroll"
                              MaxHeight="200"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="SidebarScrollViewer_MouseWheel">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource HiddenScrollBar}" />
                        <Style TargetType="RepeatButton" BasedOn="{StaticResource HiddenRepeatButton}" />
                    </ScrollViewer.Resources>
                    <TreeView ItemsSource="{Binding Viewer.Bookmarks}"
                              MinHeight="60"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0,0,0,8"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ItemContainerStyle="{StaticResource BookmarkTreeViewItem}"
                              SelectedItemChanged="OnBookmarkSelected">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                                      DataType="{x:Type models:BookmarkItem}">
                                <StackPanel Orientation="Horizontal"
                                            Height="48"
                                            Margin="4,2"
                                            Cursor="Hand">
                                    <Border Width="32"
                                            Height="44"
                                            CornerRadius="3"
                                            ClipToBounds="True"
                                            Margin="0,0,8,0"
                                            Background="#1A1A1A">
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                                   FontSize="12"
                                                   Foreground="#E0E0E0"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="120" />
                                        <TextBlock Text="{Binding PageNumber, StringFormat='페이지 {0}'}"
                                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                                   FontSize="10"
                                                   Foreground="#606060"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </Expander>

            <Expander Grid.Row="1"
                      Style="{StaticResource SidebarExpanderFill}"
                      VerticalAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="{Binding PagesLabel}"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Expander.Header>
                <ScrollViewer x:Name="ThumbnailScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              VerticalAlignment="Stretch"
                              PreviewMouseWheel="ThumbnailScrollViewer_PreviewMouseWheel"
                              ScrollChanged="OnThumbnailScrollChanged">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar"
                               BasedOn="{StaticResource SidebarThumbnailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ItemsControl x:Name="ThumbnailItemsControl"
                                  ItemsSource="{Binding Viewer.Pages}"
                                  VirtualizingPanel.IsVirtualizing="False"
                                  Focusable="False"
                                  HorizontalAlignment="Stretch"
                                  ToolTip="Ctrl+스크롤로 미리보기 크기 조절">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,4"
                                        Padding="8,6"
                                        CornerRadius="6"
                                        BorderThickness="2"
                                        Opacity="{Binding IsCut, Converter={StaticResource CutOpacityConverter}}"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToAccentBrushConverter}}"
                                        Background="{Binding IsSelected, Converter={StaticResource BoolToSelectedBgConverter}}"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="ThumbnailItem_Click"
                                        PreviewMouseRightButtonDown="ThumbnailItem_RightClick">
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource HyoContextMenu}"
                                                     Padding="0"
                                                     HasDropShadow="True"
                                                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="복사"
                                                      Command="{Binding Page.CopySelectedCommand}"
                                                      InputGestureText="Ctrl+C" />
                                            <MenuItem Header="잘라내기"
                                                      Command="{Binding Page.CutSelectedCommand}"
                                                      InputGestureText="Ctrl+X" />
                                            <MenuItem Header="붙여넣기"
                                                      Command="{Binding Page.PasteCommand}"
                                                      IsEnabled="{Binding Page.CanPaste}"
                                                      InputGestureText="Ctrl+V" />
                                            <Separator />
                                            <MenuItem Header="북마크 추가"
                                                      Command="{Binding Viewer.AddBookmarkCommand}"
                                                      CommandParameter="{Binding Viewer.CurrentPageIndex}" />
                                            <Separator />
                                            <MenuItem Header="추출"
                                                      Command="{Binding Page.ExtractSelectedCommand}" />
                                            <MenuItem Header="이미지 변환"
                                                      Command="{Binding Page.ConvertToImageCommand}" />
                                            <MenuItem Header="삭제"
                                                      Command="{Binding Page.DeleteSelectedCommand}"
                                                      InputGestureText="Delete" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.HasOpenDocument, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="False">
                                                    <Setter Property="ContextMenu" Value="{x:Null}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border CornerRadius="4"
                                                Background="#1A1A1A"
                                                Padding="2"
                                                HorizontalAlignment="Center">
                                            <Grid Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  MinHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <Border Background="#1E1E1E"
                                                        CornerRadius="4"
                                                        Visibility="{Binding Thumbnail, Converter={StaticResource NullToVisibilityConverter}}" />
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding Thumbnail, Converter={StaticResource NotNullToVisibilityConverter}}" />
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding PageNumber}"
                                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                                   FontSize="10"
                                                   Foreground="#606060"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Expander>
        </Grid>
    </Grid>
</UserControl>
