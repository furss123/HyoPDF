<Window x:Class="HyoPDF.UI.Views.PrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        Title="인쇄"
        Width="720"
        Height="580"
        MinWidth="720"
        MinHeight="580"
        Background="{Binding DialogBackground}"
        Foreground="{Binding TextPrimary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrintComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}"
                             Value="False">
                    <Setter Property="Background" Value="#FFFFFF" />
                    <Setter Property="Foreground" Value="#1A1A1A" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsHighlighted, RelativeSource={RelativeSource Self}}"
                                   Value="True" />
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                   Value="False" />
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#2A2A2A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsHighlighted, RelativeSource={RelativeSource Self}}"
                                   Value="True" />
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                   Value="False" />
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#E8E8E8" />
                    <Setter Property="Foreground" Value="#1A1A1A" />
                </MultiDataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4A9FE0" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <ControlTemplate x:Key="PrintComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="DropDownToggle"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Focusable="False"
                              ClickMode="Press">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Height="34"
                                    Cursor="Hand">
                                <Grid>
                                    <ContentPresenter Margin="10,0,30,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left" />
                                    <TextBlock Text="▾"
                                               Foreground="#909090"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <ContentPresenter IsHitTestVisible="False"
                                  Margin="10,0,30,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                  TextElement.FontSize="13" />

                <Popup x:Name="PART_Popup"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=DropDownToggle}"
                       PopupAnimation="Fade">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4"
                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                        <ScrollViewer MaxHeight="200"
                                      SnapsToDevicePixels="True"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{Binding LeftPanelBackground}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16">
                        <!-- 프린터 -->
                        <TextBlock Text="프린터"
                                   Foreground="{Binding SectionLabel}"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <ComboBox x:Name="PrinterComboBox"
                                  ItemsSource="{Binding Printers}"
                                  SelectedItem="{Binding SelectedPrinter}"
                                  Height="34"
                                  Margin="0,0,0,16"
                                  Background="{Binding InputBackground}"
                                  Foreground="{Binding TextPrimary}"
                                  BorderBrush="{Binding InputBorder}"
                                  BorderThickness="1"
                                  ItemContainerStyle="{StaticResource PrintComboBoxItemStyle}"
                                  Template="{StaticResource PrintComboBoxTemplate}" />

                        <!-- 페이지 범위 -->
                        <TextBlock Text="페이지 범위"
                                   Foreground="{Binding SectionLabel}"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <RadioButton Content="전체"
                                     GroupName="PageRange"
                                     Foreground="{Binding TextPrimary}"
                                     IsChecked="{Binding IsAllPages}"
                                     Margin="0,0,0,3" />
                        <RadioButton Content="현재 페이지"
                                     GroupName="PageRange"
                                     Foreground="{Binding TextPrimary}"
                                     IsChecked="{Binding IsCurrentPage}"
                                     Margin="0,0,0,3" />
                        <RadioButton Content="직접 입력"
                                     GroupName="PageRange"
                                     Foreground="{Binding TextPrimary}"
                                     IsChecked="{Binding IsCustomRange}"
                                     Margin="0,0,0,3" />
                        <TextBox Visibility="{Binding IsCustomRange, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Margin="0,6,0,16"
                                 Background="{Binding InputBackground}"
                                 Foreground="{Binding TextPrimary}"
                                 BorderBrush="{Binding CustomRangeBorderBrush}"
                                 Padding="8,6"
                                 FontSize="12"
                                 ToolTip="예: 1-3, 5, 7-9"
                                 Text="{Binding CustomRange, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- 매수 -->
                        <TextBlock Text="매수"
                                   Foreground="{Binding SectionLabel}"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}"
                                 Width="64"
                                 HorizontalAlignment="Left"
                                 Background="{Binding InputBackground}"
                                 Foreground="{Binding TextPrimary}"
                                 BorderBrush="{Binding InputBorder}"
                                 Padding="8,6"
                                 Margin="0,0,0,0" />
                        <CheckBox Content="한 부씩 인쇄"
                                  IsChecked="{Binding Collate}"
                                  Foreground="{Binding TextPrimary}"
                                  Margin="0,6,0,16" />

                        <!-- 한 장에 페이지 수 -->
                        <TextBlock Text="한 장에 페이지 수"
                                   Foreground="{Binding SectionLabel}"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <ComboBox x:Name="PagesPerSheetComboBox"
                                  ItemsSource="{Binding PagesPerSheetOptions}"
                                  SelectedItem="{Binding SelectedPagesPerSheet}"
                                  Height="34"
                                  Margin="0,0,0,16"
                                  Background="{Binding InputBackground}"
                                  Foreground="{Binding TextPrimary}"
                                  BorderBrush="{Binding InputBorder}"
                                  BorderThickness="1"
                                  ItemContainerStyle="{StaticResource PrintComboBoxItemStyle}"
                                  Template="{StaticResource PrintComboBoxTemplate}" />

                        <!-- 페이지 맞춤 -->
                        <TextBlock Text="페이지 맞춤"
                                   Foreground="{Binding SectionLabel}"
                                   FontSize="11"
                                   Margin="0,0,0,6" />
                        <RadioButton Content="페이지에 맞춤"
                                     Foreground="{Binding TextPrimary}"
                                     IsChecked="{Binding IsFitToPage}"
                                     Margin="0,0,0,4" />
                        <RadioButton Content="실제 크기"
                                     Foreground="{Binding TextPrimary}"
                                     IsChecked="{Binding IsActualSize}"
                                     Margin="0,0,0,4" />
                        <CheckBox Content="양면 인쇄"
                                  IsChecked="{Binding Duplex}"
                                  Foreground="{Binding TextPrimary}"
                                  Margin="0,4,0,4" />
                        <CheckBox Content="회색조 인쇄"
                                  IsChecked="{Binding Grayscale}"
                                  Foreground="{Binding TextPrimary}"
                                  Margin="0,4,0,16" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Rectangle Grid.Column="0"
                       HorizontalAlignment="Right"
                       Width="1"
                       Fill="{Binding PanelDivider}"
                       VerticalAlignment="Stretch" />

            <Grid Grid.Column="1" Background="{Binding PreviewBackground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="20">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                    <Button Content="◀"
                            Width="32"
                            Height="32"
                            Background="{Binding InputBackground}"
                            Foreground="{Binding TextPrimary}"
                            BorderBrush="{Binding InputBorder}"
                            BorderThickness="1"
                            Command="{Binding PrevPageCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Foreground="{Binding TextPrimary}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               Text="{Binding PreviewPageText}" />
                    <Button Content="▶"
                            Width="32"
                            Height="32"
                            Background="{Binding InputBackground}"
                            Foreground="{Binding TextPrimary}"
                            BorderBrush="{Binding InputBorder}"
                            BorderThickness="1"
                            Command="{Binding NextPageCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Background="{Binding BottomBarBackground}"
                BorderBrush="{Binding BottomBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <TextBlock Text="{Binding TotalSheetsText}"
                           Foreground="{Binding TextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="취소"
                            Width="80"
                            Height="36"
                            Background="Transparent"
                            Foreground="{Binding MutedButtonForeground}"
                            BorderBrush="{Binding InputBorder}"
                            Margin="0,0,8,0"
                            Command="{Binding CancelCommand}" />
                    <Button Content="인쇄 시작"
                            Width="100"
                            Height="36"
                            Background="#4A9FE0"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding PrintCommand}"
                            Click="PrintStartButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
