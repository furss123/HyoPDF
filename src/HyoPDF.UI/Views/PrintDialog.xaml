<Window x:Class="HyoPDF.UI.Views.PrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HyoPDF.UI.Converters"
        Title="Print"
        Width="520"
        Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}">
    <Window.Resources>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <Style x:Key="SectionLabel" TargetType="TextBlock" BasedOn="{StaticResource TextSecondary}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Printer"
                   Style="{StaticResource SectionLabel}" />
        <ComboBox Grid.Row="1"
                  Style="{StaticResource FieldCombo}"
                  ItemsSource="{Binding AvailablePrinters}"
                  SelectedItem="{Binding SelectedPrinter}"
                  Margin="0,0,0,12" />

        <TextBlock Grid.Row="2"
                   Text="Page range"
                   Style="{StaticResource SectionLabel}" />
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <RadioButton Content="All pages"
                         IsChecked="{Binding IsAllPagesSelected}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Margin="0,0,0,4" />
            <RadioButton Content="Current page"
                         IsChecked="{Binding IsCurrentPageSelected}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Custom:"
                             IsChecked="{Binding IsCustomRangeSelected}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                <TextBox Width="200"
                         Margin="8,0,0,0"
                         Style="{StaticResource FieldTextBox}"
                         IsEnabled="{Binding IsCustomRangeSelected}"
                         Text="{Binding CustomRange, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="e.g. 1-3,5,7-9" />
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="Pages per sheet"
                   Style="{StaticResource SectionLabel}" />
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource FieldCombo}"
                      ItemsSource="{Binding PagesPerSheetOptions}"
                      SelectedItem="{Binding PagesPerSheet}"
                      VerticalAlignment="Top" />

            <Border Grid.Column="2"
                    Background="{DynamicResource BgSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}"
                    Padding="8"
                    VerticalAlignment="Top"
                    MinHeight="120">
                <ItemsControl ItemsSource="{Binding SheetPreviewCells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding DataContext.SheetPreviewColumns, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Rows="{Binding DataContext.SheetPreviewRows, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource BgBaseBrush}"
                                    CornerRadius="2">
                                <TextBlock Text="{Binding}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextSecondary}"
                                           FontSize="11" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>

        <StackPanel Grid.Row="6" Margin="0,0,0,8">
            <CheckBox Content="Double-sided (duplex)"
                      IsChecked="{Binding IsDuplex}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,0,6" />
            <CheckBox Content="Fit to page"
                      IsChecked="{Binding IsFitToPage}"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Copies"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox Width="64"
                     Style="{StaticResource FieldTextBox}"
                     Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <TextBlock Grid.Row="8"
                   Text="{Binding ErrorMessage}"
                   Foreground="#E57373"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}" />

        <StackPanel Grid.Row="9"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Print preview"
                    Style="{StaticResource ToolbarButton}"
                    Margin="0,0,8,0"
                    Command="{Binding PrintPreviewCommand}" />
            <Button Content="Cancel"
                    Style="{StaticResource ToolbarButton}"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"
                    IsCancel="True" />
            <Button Content="Print"
                    Style="{StaticResource ToolbarButton}"
                    Command="{Binding PrintCommand}"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
