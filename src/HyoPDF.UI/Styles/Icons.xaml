<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ToolbarVoxelIcon" TargetType="Image">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
    </Style>

    <BitmapImage x:Key="ToolbarIconOpenFolder"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/open-folder.png" />
    <BitmapImage x:Key="ToolbarIconClosedFolder"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/closed-folder.png" />
    <BitmapImage x:Key="ToolbarIconZoomIn"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/zoom-in.png" />
    <BitmapImage x:Key="ToolbarIconZoomOut"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/zoom-out.png" />
    <BitmapImage x:Key="ToolbarIconRotate"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/rotate.png" />
    <BitmapImage x:Key="ToolbarIconMerge"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/merge.png" />
    <BitmapImage x:Key="ToolbarIconSplit"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/split.png" />
    <BitmapImage x:Key="ToolbarIconCompress"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/compress.png" />
    <BitmapImage x:Key="ToolbarIconPrint"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/print1.png" />
    <BitmapImage x:Key="ToolbarIconSettings"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/Toolbar/settings.png" />

    <BitmapImage x:Key="AppIconImage"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/app-icon-512.png" />
    <BitmapImage x:Key="DeskIllustrationImage"
                 UriSource="pack://application:,,,/HyoPDF.UI;component/Assets/Icons/desk-illustration-1200.png" />

</ResourceDictionary>
